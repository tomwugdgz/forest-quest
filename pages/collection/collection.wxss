/* pages/collection/collection.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 140rpx;
  background: #EAF3DE;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.header .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #3D6B1A;
}

.header .count {
  font-size: 28rpx;
  color: #888780;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.filter-item {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  background: #FFFFFF;
  font-size: 26rpx;
  color: #5A5A5A;
  border: 2rpx solid #D4E5B5;
  white-space: nowrap;
}

.filter-item.active {
  background: #639922;
  color: #FFFFFF;
  border-color: #639922;
}

.rarity-filter {
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.rarity-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  background: #FFFFFF;
  font-size: 24rpx;
  color: #5A5A5A;
  border: 2rpx solid #E0E0E0;
}

.rarity-item.active {
  border-color: #639922;
  background: #F0F7E0;
}

.n-dot { color: #888; font-size: 20rpx; }
.r-dot { color: #2196F3; font-size: 20rpx; }
.sr-dot { color: #FF9800; font-size: 20rpx; }

/* 卡片网格 */
.collection-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.collection-card {
  width: calc(50% - 10rpx);
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 3rpx solid #D4E5B5;
  position: relative;
  transition: all 0.3s;
}

.collection-card.collected {
  border-color: #639922;
  box-shadow: 0 4rpx 12rpx rgba(99, 153, 34, 0.15);
}

.collection-card.hidden {
  background: #F5F5F5;
  border-color: #E0E0E0;
}

.card-emoji {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.card-emoji.blurred {
  filter: blur(10rpx);
}

.card-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #3D6B1A;
  text-align: center;
  margin-bottom: 8rpx;
}

.card-name.blurred {
  color: #CCC;
}

.rarity-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: #FFF;
}

.rarity-badge.N { background: #9E9E9E; }
.rarity-badge.R { background: #2196F3; }
.rarity-badge.SR { background: linear-gradient(135deg, #FF9800, #FF5722); }

/* 角色详情弹窗 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal.card-detail {
  width: 80%;
  background: #FFFFFF;
  border-radius: 30rpx;
  padding: 50rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-emoji {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #3D6B1A;
  margin-bottom: 10rpx;
}

.detail-rarity {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: #FFF;
  margin-bottom: 20rpx;
}

.detail-rarity.N { background: #9E9E9E; }
.detail-rarity.R { background: #2196F3; }
.detail-rarity.SR { background: linear-gradient(135deg, #FF9800, #FF5722); }

.detail-desc {
  font-size: 28rpx;
  color: #5A5A5A;
  text-align: center;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.detail-reward {
  display: flex;
  gap: 30rpx;
  margin-bottom: 24rpx;
}

.detail-reward text {
  font-size: 28rpx;
  color: #3D6B1A;
  font-weight: bold;
}

.detail-status text {
  font-size: 28rpx;
  font-weight: bold;
}

.collected-text { color: #639922; }
.not-collected-text { color: #FF5722; }

.modal-close {
  margin-top: 30rpx;
  padding: 16rpx 60rpx;
  background: #639922;
  color: #FFF;
  border-radius: 30rpx;
  font-size: 30rpx;
  font-weight: bold;
}
