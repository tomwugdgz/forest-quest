/* pages/task/task.wxss */
.container {
  min-height: 100vh;
  background: #F1EFE8;
  padding: 20rpx 24rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #2C2C2A;
  margin: 24rpx 0 16rpx;
}

.section-sub {
  font-size: 24rpx;
  color: #888780;
  font-weight: 400;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  transition: all 0.3s;
}

.task-card.completed {
  opacity: 0.6;
}

.task-left {
  margin-right: 20rpx;
}

.task-emoji {
  font-size: 56rpx;
}

.task-content {
  flex: 1;
  min-width: 0;
}

.task-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.task-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #2C2C2A;
}

.rarity-tag {
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: #fff;
}

.rarity-tag.N { background: #639922; }
.rarity-tag.R { background: #378ADD; }
.rarity-tag.SR { background: #BA7517; }

.task-task {
  font-size: 26rpx;
  color: #5F5E5A;
  display: block;
  margin-bottom: 4rpx;
}

.task-desc {
  font-size: 22rpx;
  color: #888780;
  font-style: italic;
  display: block;
  margin-bottom: 8rpx;
}

.task-reward {
  display: flex;
  gap: 20rpx;
}

.reward {
  font-size: 22rpx;
  font-weight: 500;
}

.task-right {
  margin-left: 16rpx;
}

.check-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid #D3D1C7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-btn.checked {
  background: #639922;
  border-color: #639922;
}

.check-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #5F5E5A;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #888780;
  margin-bottom: 32rpx;
}

.go-draw-btn {
  padding: 20rpx 60rpx;
  background: #639922;
  border-radius: 24rpx;
}

.go-draw-btn text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

/* 统计卡片 */
.stats-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 24rpx 0;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2C2C2A;
}

.stats-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #639922;
}

.progress-bar {
  height: 16rpx;
  background: #EAF3DE;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #97C459, #639922);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.stats-total {
  display: flex;
  justify-content: space-around;
}

.total-xp, .total-gold {
  font-size: 24rpx;
  font-weight: 500;
}

.total-xp { color: #639922; }
.total-gold { color: #854F0B; }

/* 日期导航 */
.date-section {
  margin: 24rpx 0;
}

.date-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.date-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff;
}

.date-text {
  font-size: 28rpx;
  color: #2C2C2A;
  font-weight: 500;
}

/* 历史记录 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.history-date {
  font-size: 24rpx;
  color: #5F5E5A;
}

.history-count {
  font-size: 24rpx;
  color: #639922;
}
