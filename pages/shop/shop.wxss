/* pages/shop/shop.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 140rpx;
  background: #EAF3DE;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.header .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #3D6B1A;
}

.gold-balance {
  background: #FFF8E1;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #F57C00;
  border: 2rpx solid #FFE082;
}

.section-title {
  margin: 30rpx 0 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #3D6B1A;
  border-left: 6rpx solid #639922;
  padding-left: 16rpx;
}

.shop-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.shop-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  gap: 20rpx;
  border: 2rpx solid #D4E5B5;
  transition: all 0.3s;
}

.shop-item:active {
  transform: scale(0.98);
  background: #F0F7E0;
}

.item-icon {
  font-size: 52rpx;
  width: 80rpx;
  text-align: center;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #3D6B1A;
  margin-bottom: 6rpx;
}

.item-desc {
  font-size: 24rpx;
  color: #888780;
}

.item-price {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.item-price.affordable {
  background: #639922;
  color: #FFFFFF;
}

.item-price.expensive {
  background: #F5F5F5;
  color: #CCC;
}

/* 已兑换列表 */
.redeemed-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.redeemed-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  gap: 16rpx;
  opacity: 0.7;
}

.redeemed-icon {
  font-size: 36rpx;
}

.redeemed-name {
  flex: 1;
  font-size: 28rpx;
  color: #5A5A5A;
}

.redeemed-time {
  font-size: 22rpx;
  color: #AAA;
}

/* 购买确认弹窗 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal.buy-confirm {
  width: 75%;
  background: #FFFFFF;
  border-radius: 30rpx;
  padding: 50rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.confirm-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.confirm-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #3D6B1A;
  margin-bottom: 10rpx;
}

.confirm-desc {
  font-size: 26rpx;
  color: #888780;
  margin-bottom: 20rpx;
  text-align: center;
}

.confirm-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #F57C00;
  margin-bottom: 30rpx;
}

.confirm-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  padding: 18rpx;
  border-radius: 30rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
}

.btn-cancel {
  background: #F5F5F5;
  color: #5A5A5A;
}

.btn-confirm {
  background: #639922;
  color: #FFFFFF;
}
