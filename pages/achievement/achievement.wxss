/* pages/achievement/achievement.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 140rpx;
  background: #EAF3DE;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.header .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #3D6B1A;
}

.header .stats {
  font-size: 26rpx;
  color: #888780;
}

.progress-bar {
  height: 40rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  position: relative;
  border: 2rpx solid #D4E5B5;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #639922, #8BC34A);
  border-radius: 20rpx;
  transition: width 0.5s;
}

.progress-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  font-weight: bold;
  color: #3D6B1A;
}

.achievement-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.achievement-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  gap: 20rpx;
  border: 2rpx solid #D4E5B5;
}

.achievement-card.locked {
  opacity: 0.5;
  border-color: #E0E0E0;
}

.achievement-card.unlocked {
  border-color: #639922;
  box-shadow: 0 4rpx 12rpx rgba(99, 153, 34, 0.15);
}

.ach-icon {
  font-size: 52rpx;
  width: 80rpx;
  text-align: center;
}

.ach-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.ach-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #3D6B1A;
  margin-bottom: 4rpx;
}

.ach-desc {
  font-size: 24rpx;
  color: #888780;
  margin-bottom: 6rpx;
}

.ach-reward text {
  font-size: 24rpx;
  font-weight: bold;
  color: #F57C00;
}

.ach-status text {
  font-size: 32rpx;
}
