<!--pages/achievement/achievement.wxml-->
<view class="container">
  <view class="header">
    <text class="title">🏆 成就大厅</text>
    <view class="stats">
      <text>已解锁 {{unlockedCount}}/{{totalAchievements.length}}</text>
    </view>
  </view>

  <!-- 成就进度 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    <text class="progress-text">{{progressPercent}}%</text>
  </view>

  <!-- 成就列表 -->
  <view class="achievement-list">
    <view class="achievement-card {{item.unlocked ? 'unlocked' : 'locked'}}" wx:for="{{totalAchievements}}" wx:key="id">
      <view class="ach-icon">{{item.unlocked ? item.icon : '🔒'}}</view>
      <view class="ach-info">
        <text class="ach-name">{{item.name}}</text>
        <text class="ach-desc">{{item.description}}</text>
        <view class="ach-reward" wx:if="{{item.unlocked}}">
          <text>🪙 +{{item.rewardGold}}</text>
        </view>
      </view>
      <view class="ach-status" wx:if="{{item.unlocked}}">
        <text>✅</text>
      </view>
    </view>
  </view>
</view>
