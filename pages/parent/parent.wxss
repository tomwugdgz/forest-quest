/* pages/parent/parent.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
  background: #EAF3DE;
  min-height: 100vh;
}

/* 登录面板 */
.login-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  background: #FFFFFF;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #3D6B1A;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #888780;
  margin-bottom: 40rpx;
}

.password-input {
  margin-bottom: 30rpx;
}

.password-field {
  width: 300rpx;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  letter-spacing: 12rpx;
  border: 2rpx solid #D4E5B5;
}

.login-btn {
  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #639922, #8BC34A);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.login-btn text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}

.login-hint {
  font-size: 24rpx;
  color: #AAA;
}

/* 设置面板 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.header .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #3D6B1A;
}

.logout-btn {
  padding: 10rpx 24rpx;
  background: #F5F5F5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #FF5722;
}

/* 通用区块 */
.section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #D4E5B5;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3D6B1A;
  margin-bottom: 20rpx;
  display: block;
}

/* 孩子选择 */
.child-selector {
  display: flex;
  gap: 16rpx;
}

.child-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  font-size: 28rpx;
  color: #5A5A5A;
}

.child-tab.active {
  background: #639922;
  color: #FFFFFF;
}

/* 年龄段选择 */
.age-selector {
  display: flex;
  gap: 12rpx;
}

.age-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  font-size: 24rpx;
  color: #5A5A5A;
}

.age-tab.active {
  background: #639922;
  color: #FFFFFF;
}

/* 滑块 */
.slider-section {
  padding: 10rpx 0;
}

.slider-hint {
  font-size: 24rpx;
  color: #888780;
  text-align: center;
  display: block;
  margin-top: 10rpx;
}

/* 金币倍率 */
.multiplier-selector {
  display: flex;
  gap: 12rpx;
}

.mult-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 8rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  font-size: 24rpx;
  color: #5A5A5A;
}

.mult-tab.active {
  background: #FF9800;
  color: #FFFFFF;
}

/* 修改密码 */
.change-password {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.password-field-sm {
  flex: 1;
  height: 70rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  border: 2rpx solid #D4E5B5;
}

.change-btn {
  padding: 14rpx 30rpx;
  background: #639922;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: bold;
}

/* 数据管理 */
.data-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.action-btn-warning {
  background: #FFF8E1;
  color: #F57C00;
  border: 2rpx solid #FFE082;
}

.action-btn-danger {
  background: #FFEBEE;
  color: #E53935;
  border: 2rpx solid #FFCDD2;
}

/* 统计面板 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-card {
  width: calc(50% - 8rpx);
  background: #F0F7E0;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #3D6B1A;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #888780;
}
